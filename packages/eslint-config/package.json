{
  "name": "@workspace/eslint-config",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./base": "./base.js",
    "./node": "./node.js",
    "./react": "./react.js"
  },
  "scripts": {
    "lint": "eslint \"**/*.{js,mjs,cjs,jsx,ts,tsx}\" --max-warnings=0 --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"**/*.{js,mjs,cjs,jsx,ts,tsx}\" --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^5.10.0",
    "@eslint/js": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.0"
  }
}
